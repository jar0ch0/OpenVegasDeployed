# Required for runtime auth validation in server/middleware/auth.py
SUPABASE_JWT_SECRET=replace_with_supabase_jwt_secret

# Required for runtime database access in server/services/dependencies.py
# Prefer Supabase connection pooler URI from Dashboard -> Connect
DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/postgres

# Optional in current code (placeholder Redis is used if empty)
REDIS_URL=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ORG_PRICE_ID=
APP_BASE_URL=http://127.0.0.1:8085
CHECKOUT_SUCCESS_URL=http://127.0.0.1:8085/ui?checkout=success
CHECKOUT_CANCEL_URL=http://127.0.0.1:8085/ui?checkout=cancel

# Billing pricing bounds
V_PER_USD=100
TOPUP_MIN_USD=1
TOPUP_MAX_USD=500
ORG_MONTHLY_MIN_USD=10

# Runtime toggles
OPENVEGAS_TEST_MODE=0
STORE_ENABLED=1
INFERENCE_ENABLED=1
AGENT_RUNTIME_ENABLED=1
CASINO_HUMAN_ENABLED=0
MINT_AUDIT_ENABLED=1
OPENVEGAS_COMPANY_MINT_DEFAULT=1
CASINO_SESSION_TTL_SECONDS=1800
CASINO_HUMAN_SESSION_TTL_SECONDS=1800
CASINO_HUMAN_ROUND_TTL_SECONDS=600

# Demo mode controls
OPENVEGAS_DEMO_ALWAYS_WIN_ENABLED=0
OPENVEGAS_DEMO_ADMIN_USER_IDS=
OPENVEGAS_DEMO_ALLOW_LOCAL_OPEN=0
OPENVEGAS_DEMO_MAX_ATTEMPTS=120
OPENVEGAS_DEMO_MAX_ATTEMPTS_HORSE=120
OPENVEGAS_DEMO_MAX_ATTEMPTS_SKILLSHOT=80
OPENVEGAS_DEMO_ADMIN_AUTOFUND_ENABLED=1
OPENVEGAS_DEMO_ADMIN_AUTOFUND_MIN=1000
OPENVEGAS_DEMO_ADMIN_AUTOFUND_TOPUP=1500
OPENVEGAS_DEMO_ADMIN_AUTOFUND_MAX_CYCLES=20
OPENVEGAS_DEMO_ADMIN_AUTOFUND_READ_COOLDOWN_SEC=0

# Horse quote pricing
OPENVEGAS_HORSE_QUOTE_TTL_SEC=60
OPENVEGAS_HORSE_QUOTE_MAX_ACTIVE_PER_USER=5
OPENVEGAS_HORSE_QUOTE_MAX_CREATE_PER_MIN=30
OPENVEGAS_HORSE_QUOTE_RETENTION_DAYS=7
OPENVEGAS_HORSE_IDEMPOTENCY_RETENTION_DAYS=14
