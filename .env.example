# Required for runtime auth validation in server/middleware/auth.py
SUPABASE_JWT_SECRET=replace_with_supabase_jwt_secret
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Browser signup email confirmation redirect.
# If OPENVEGAS_AUTH_EMAIL_REDIRECT_URL is set, it is used as-is.
# Otherwise redirect resolves to {request_origin}{OPENVEGAS_AUTH_EMAIL_REDIRECT_PATH}.
OPENVEGAS_AUTH_EMAIL_REDIRECT_URL=
OPENVEGAS_AUTH_EMAIL_REDIRECT_PATH=/ui/login?mode=signup&next=%2Fui%2Fbalance

# Required for runtime database access in server/services/dependencies.py
# Prefer Supabase connection pooler URI from Dashboard -> Connect
DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/postgres

# Optional in current code (placeholder Redis is used if empty)
REDIS_URL=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ORG_PRICE_ID=
APP_BASE_URL=http://127.0.0.1:8085
CHECKOUT_SUCCESS_URL=http://127.0.0.1:8085/ui?checkout=success
CHECKOUT_CANCEL_URL=http://127.0.0.1:8085/ui?checkout=cancel

# Billing pricing bounds
V_PER_USD=100
TOPUP_MIN_USD=10
USER_SUBSCRIPTION_MIN_USD=10
TOPUP_MAX_USD=500
ORG_MONTHLY_MIN_USD=10
TOPUP_LOW_BALANCE_FLOOR_USD=5.00
TOPUP_CRITICAL_BALANCE_FLOOR_V=90
STARTER_GRANT_V=150
BNPL_CONTINUATION_MAX_V=50
BNPL_CONTINUATION_COOLDOWN_HOURS=168
BNPL_CONTINUATION_RISK_BLOCKED_USER_IDS=

# Runtime toggles
OPENVEGAS_TEST_MODE=0
STORE_ENABLED=1
INFERENCE_ENABLED=1
AGENT_RUNTIME_ENABLED=1
OPENVEGAS_CONTEXT_ENABLED=1
OPENVEGAS_CONTEXT_MAX_MESSAGES=200
OPENVEGAS_CONTEXT_TTL_HOURS=72
OPENVEGAS_CONTEXT_HISTORY_BUDGET_FRACTION=0.60
OPENVEGAS_CONTEXT_COMPACTION_ENABLED=1
OPENVEGAS_CONTEXT_COMPACTION_TRIGGER_MESSAGES=120
OPENVEGAS_CONTEXT_COMPACTION_KEEP_RECENT_MESSAGES=60
OPENVEGAS_CONTEXT_COMPACTION_MAX_SUMMARY_CHARS=6000
# Optional override. If empty, server uses model-based heuristic defaults.
OPENVEGAS_CONTEXT_MODEL_WINDOW_TOKENS=128000
OPENVEGAS_FEATURES_ENABLED=1
# Local/dev default: .env overrides stale exported shell vars.
OPENVEGAS_DOTENV_OVERRIDE=1
OPENVEGAS_ENABLE_WEB_SEARCH=1
OPENVEGAS_ENABLE_FILES=1
OPENVEGAS_ENABLE_VISION=1
OPENVEGAS_ENABLE_MCP=0
OPENVEGAS_ENABLE_CODE_EXEC=0
OPENVEGAS_ENABLE_IMAGE_GEN=0
OPENVEGAS_ENABLE_REALTIME_VOICE=0
OPENVEGAS_OPENAI_WEB_SEARCH_ENABLED=1
OPENVEGAS_CHAT_WEB_SEARCH_DEFAULT=1
OPENVEGAS_CHAT_WEB_SEARCH_SOURCES_MAX=8
OPENVEGAS_ROLLOUT_WEB_SEARCH_PCT=100
OPENVEGAS_CAPABILITY_OVERRIDES_JSON=
OPENVEGAS_MCP_ALLOWLIST=
OPENVEGAS_CHAT_MAX_ATTACHMENTS=3
OPENVEGAS_CHAT_MAX_ATTACHMENT_BYTES=20971520
OPENVEGAS_CHAT_ALLOWED_MIME=text/*,image/*,application/pdf,application/json,application/xml,application/octet-stream
OPENVEGAS_CHAT_ATTACHMENT_PREVIEW_MAX_CHARS=6000
OPENVEGAS_CHAT_ATTACH_RESOLVE_DEADLINE_MS=500
OPENVEGAS_CHAT_AUTO_CLIPBOARD_IMAGE_ATTACH=0
OPENVEGAS_CHAT_ATTACHMENT_STATUS_STYLE=dim
OPENVEGAS_CHAT_FULLSCREEN=0
# Keep sensitive OS paths blocked from auto-attach resolution by default.
OPENVEGAS_CHAT_ATTACH_BLOCK_SENSITIVE=1
OPENVEGAS_CHAT_ATTACH_BLOCK_PATH_PREFIXES=/etc,/proc,/sys,/dev,/private/etc,/private/var/run,/var/run,~/Library/Keychains
OPENVEGAS_FILE_UPLOAD_INIT_TTL_SEC=900
OPENVEGAS_FILE_UPLOAD_COMPLETED_TTL_SEC=259200
OPENVEGAS_FILE_UPLOAD_CLEANUP_RETENTION_SEC=86400
OPENVEGAS_FILE_UPLOAD_ALLOWED_MIME=text/*,image/*,audio/*,application/pdf,application/json,application/xml,application/octet-stream
OPENVEGAS_CODE_EXEC_RUNTIME=local
OPENVEGAS_CODE_EXEC_ALLOW_NETWORK=0
OPENVEGAS_CODE_EXEC_MAX_TIMEOUT_SEC=30
OPENVEGAS_CODE_EXEC_MAX_CODE_CHARS=40000
OPENVEGAS_CODE_EXEC_MAX_OUTPUT_CHARS=12000
OPENVEGAS_CODE_EXEC_CONTAINER_IMAGE=python:3.11-alpine
OPENVEGAS_CODE_EXEC_CONTAINER_MEMORY_MB=512
OPENVEGAS_CODE_EXEC_CONTAINER_CPUS=1.0
OPENVEGAS_CODE_EXEC_MAX_ARTIFACTS=10
OPENVEGAS_CODE_EXEC_ARTIFACT_MAX_BYTES=5242880
OPENVEGAS_CODE_EXEC_ARTIFACT_INLINE_MAX_BYTES=262144
OPENVEGAS_CODE_EXEC_ARTIFACT_TEXT_PREVIEW_CHARS=4000
OPENVEGAS_REALTIME_TIMEOUT_SEC=8

OPENVEGAS_CHAT_VOICE_STOP_TIMEOUT_SEC=20
OPENVEGAS_CHAT_VOICE_UPLOAD_TIMEOUT_SEC=30
OPENVEGAS_CHAT_VOICE_TRANSCRIBE_TIMEOUT_SEC=90
OPENVEGAS_ALERT_P95_LATENCY_MS=4000
OPENVEGAS_ALERT_HTTP_P95_LATENCY_MS=2000
OPENVEGAS_ALERT_HTTP_5XX_RATE=0.02
OPENVEGAS_ALERT_TOOL_FAIL_RATE=0.20
OPENVEGAS_ALERT_FALLBACK_RATE=0.25
OPENVEGAS_ALERT_AVG_COST_USD=3.0
OPENVEGAS_ALERT_UPLOAD_FAILURE_RATE=0.10
OPENVEGAS_ALERT_AUTH_REFRESH_FAILURE_RATE=0.25
OPENVEGAS_ALERT_PAYMENT_FAILURE_RATE=0.10
OPENVEGAS_ROLLBACK_OWNER=platform-oncall
OPENVEGAS_ROLLBACK_CHECKLIST_JSON=
CASINO_HUMAN_ENABLED=0
OPENVEGAS_MIN_GAME_WAGER_V=50
OPENVEGAS_QR_AUTO_INSTALL=1
MINT_AUDIT_ENABLED=1
OPENVEGAS_COMPANY_MINT_DEFAULT=1
CASINO_SESSION_TTL_SECONDS=1800
CASINO_HUMAN_SESSION_TTL_SECONDS=1800
CASINO_HUMAN_ROUND_TTL_SECONDS=600

# Debug/trace
OPENVEGAS_TOOL_DEBUG=0
OPENVEGAS_IDE_BRIDGE_TRACE=0

# Demo mode controls
# Preferred aliases for QA/content workflows:
# OPENVEGAS_WIN_ALWAYS=Y|N (or 1|0)
# OPENVEGAS_WIN_ALWAYS_USER_IDS=comma,separated,user_ids
# If OPENVEGAS_WIN_ALWAYS=Y and no allowlist is set, all accounts are enabled.
OPENVEGAS_DEMO_ALWAYS_WIN_ENABLED=0
OPENVEGAS_DEMO_ADMIN_USER_IDS=
OPENVEGAS_DEMO_ALLOW_LOCAL_OPEN=0
OPENVEGAS_DEMO_MAX_ATTEMPTS=120
OPENVEGAS_DEMO_MAX_ATTEMPTS_HORSE=120
OPENVEGAS_DEMO_MAX_ATTEMPTS_SKILLSHOT=80
OPENVEGAS_DEMO_ADMIN_AUTOFUND_ENABLED=1
OPENVEGAS_DEMO_ADMIN_AUTOFUND_MIN=1000
OPENVEGAS_DEMO_ADMIN_AUTOFUND_TOPUP=1500
OPENVEGAS_DEMO_ADMIN_AUTOFUND_MAX_CYCLES=20
OPENVEGAS_DEMO_ADMIN_AUTOFUND_READ_COOLDOWN_SEC=0

# Horse quote pricing
OPENVEGAS_HORSE_QUOTE_TTL_SEC=60
OPENVEGAS_HORSE_QUOTE_MAX_ACTIVE_PER_USER=5
OPENVEGAS_HORSE_QUOTE_MAX_CREATE_PER_MIN=30
OPENVEGAS_HORSE_QUOTE_RETENTION_DAYS=7
OPENVEGAS_HORSE_IDEMPOTENCY_RETENTION_DAYS=14
OPENVEGAS_ENABLE_TOUCHID=0
OPENVEGAS_TOUCHID_REQUIRE_BIOMETRIC=1
