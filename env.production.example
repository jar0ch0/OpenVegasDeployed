# ============================================
#  OpenVegas — Production Environment Variables
# ============================================
#  These are the DEPLOYMENT-CRITICAL variables you must set in Railway's
#  "Variables" tab. Your repo's .env.example has the fuller reference
#  list; this file covers only what's needed to get the service running.
#
#  For the complete reference, see .env.example at the repo root.
# ============================================

# ── Runtime ─────────────────────────────────
OPENVEGAS_RUNTIME_ENV=production
# PORT is injected by Railway automatically — do not set it manually.

# ── Supabase Auth ───────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Database ────────────────────────────────
# The POOLER URL (port 6543) — used by the running app for all queries.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# The DIRECT URL (port 5432) — used ONLY by the migration runner for DDL.
# Get this from Supabase Dashboard → Settings → Database → Connection string → Direct.
DATABASE_DIRECT_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# ── Redis (optional — app degrades gracefully without it) ─
# Provision Railway Redis plugin, or use Upstash, or leave blank.
REDIS_URL=redis://default:password@host:port

# ── Security / Cookies ──────────────────────
OPENVEGAS_COOKIE_SECURE=1
OPENVEGAS_REQUIRE_ORIGIN_ON_POST=1
OPENVEGAS_TRUSTED_PROXY_HEADERS=1

# ── Stripe ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_ORG_PRICE_ID=price_...

# ── App URLs ────────────────────────────────
# Set these to the production app domain used by the CLI and browser flows.
OPENVEGAS_BACKEND_URL=https://app.openvegas.ai
APP_BASE_URL=https://app.openvegas.ai
CHECKOUT_SUCCESS_URL=https://app.openvegas.ai/ui/balance
CHECKOUT_CANCEL_URL=https://app.openvegas.ai/ui/balance

# ── Allowed Origins (comma-separated) ───────
ALLOWED_ORIGINS=https://app.openvegas.ai,https://openvegas.ai

# ── AI Provider Keys (set whichever you use) ─
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...

# ── Economy Defaults ────────────────────────
V_PER_USD=100
TOPUP_MIN_USD=10

# ── Feature Flags ───────────────────────────
STORE_ENABLED=true
INFERENCE_ENABLED=true
AGENT_RUNTIME_ENABLED=true
OPENVEGAS_ENABLE_FILES=1
OPENVEGAS_ENABLE_SPEECH_TO_TEXT=1
OPENVEGAS_ENABLE_REALTIME_VOICE=1

# ── See .env.example for the remaining variables ─
