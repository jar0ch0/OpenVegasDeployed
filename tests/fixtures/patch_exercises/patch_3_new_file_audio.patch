@@ -0,0 +1,187 @@
+#include "audio/audio_manager.h"
+#include <cassert>
+#include <algorithm>
+#include <cmath>
+#include <iostream>
+
+namespace audio {
+
+static constexpr int kMaxVoices = 64;
+static constexpr int kMaxListeners = 4;
+static constexpr float kDefaultMasterVolume = 0.8f;
+static constexpr float kDefaultFalloffDistance = 50.0f;
+static constexpr float kMinAudibleVolume = 0.001f;
+
+struct Voice {
+    uint32_t id = 0;
+    uint32_t sound_id = 0;
+    float volume = 1.0f;
+    float pitch = 1.0f;
+    float pan = 0.0f;
+    glm::vec3 position{0};
+    bool is_3d = false;
+    bool looping = false;
+    bool active = false;
+    float playback_position = 0.0f;
+    float fade_volume = 1.0f;
+    float fade_target = 1.0f;
+    float fade_speed = 0.0f;
+};
+
+AudioManager::AudioManager()
+    : m_master_volume(kDefaultMasterVolume)
+    , m_initialized(false)
+    , m_next_voice_id(1) {
+    m_voices.resize(kMaxVoices);
+}
+
+AudioManager::~AudioManager() {
+    if (m_initialized) {
+        shutdown();
+    }
+}
+
+bool AudioManager::initialize(const AudioConfig& config) {
+    if (m_initialized) {
+        std::cerr << "AudioManager already initialized" << std::endl;
+        return false;
+    }
+
+    m_sample_rate = config.sample_rate;
+    m_buffer_size = config.buffer_size;
+    m_channels = config.channels;
+    m_master_volume = config.master_volume;
+
+    if (!open_audio_device(config)) {
+        std::cerr << "Failed to open audio device" << std::endl;
+        return false;
+    }
+
+    m_initialized = true;
+    return true;
+}
+
+void AudioManager::shutdown() {
+    stop_all();
+    close_audio_device();
+    m_sound_cache.clear();
+    m_initialized = false;
+}
+
+uint32_t AudioManager::play_sound(uint32_t sound_id, const PlaybackParams& params) {
+    assert(m_initialized);
+
+    Voice* voice = find_free_voice();
+    if (!voice) {
+        voice = steal_lowest_priority_voice();
+        if (!voice) return 0;
+    }
+
+    voice->id = m_next_voice_id++;
+    voice->sound_id = sound_id;
+    voice->volume = params.volume;
+    voice->pitch = params.pitch;
+    voice->pan = params.pan;
+    voice->looping = params.looping;
+    voice->is_3d = false;
+    voice->active = true;
+    voice->playback_position = 0.0f;
+    voice->fade_volume = 1.0f;
+    voice->fade_target = 1.0f;
+    voice->fade_speed = 0.0f;
+
+    return voice->id;
+}
+
+uint32_t AudioManager::play_sound_3d(uint32_t sound_id, const glm::vec3& position, const PlaybackParams& params) {
+    uint32_t voice_id = play_sound(sound_id, params);
+    if (voice_id == 0) return 0;
+
+    Voice* voice = find_voice_by_id(voice_id);
+    if (voice) {
+        voice->is_3d = true;
+        voice->position = position;
+    }
+    return voice_id;
+}
+
+void AudioManager::stop_voice(uint32_t voice_id) {
+    Voice* voice = find_voice_by_id(voice_id);
+    if (voice) {
+        voice->active = false;
+    }
+}
+
+void AudioManager::stop_all() {
+    for (auto& voice : m_voices) {
+        voice.active = false;
+    }
+}
+
+void AudioManager::set_master_volume(float volume) {
+    m_master_volume = std::clamp(volume, 0.0f, 1.0f);
+}
+
+void AudioManager::set_listener_position(const glm::vec3& position, const glm::vec3& forward) {
+    m_listener_position = position;
+    m_listener_forward = glm::normalize(forward);
+}
+
+void AudioManager::fade_voice(uint32_t voice_id, float target_volume, float duration_seconds) {
+    Voice* voice = find_voice_by_id(voice_id);
+    if (!voice || !voice->active) return;
+
+    voice->fade_target = std::clamp(target_volume, 0.0f, 1.0f);
+    voice->fade_speed = (duration_seconds > 0.0f)
+        ? std::abs(voice->fade_target - voice->fade_volume) / duration_seconds
+        : 1000.0f;
+}
+
+void AudioManager::update(float dt) {
+    if (!m_initialized) return;
+
+    for (auto& voice : m_voices) {
+        if (!voice.active) continue;
+
+        // Advance playback
+        voice.playback_position += dt * voice.pitch;
+
+        // Process fade
+        if (voice.fade_volume != voice.fade_target) {
+            float step = voice.fade_speed * dt;
+            if (voice.fade_volume < voice.fade_target) {
+                voice.fade_volume = std::min(voice.fade_volume + step, voice.fade_target);
+            } else {
+                voice.fade_volume = std::max(voice.fade_volume - step, voice.fade_target);
+            }
+            if (voice.fade_volume < kMinAudibleVolume && voice.fade_target <= 0.0f) {
+                voice.active = false;
+                continue;
+            }
+        }
+
+        // 3D attenuation
+        float spatial_volume = 1.0f;
+        if (voice.is_3d) {
+            float distance = glm::length(voice.position - m_listener_position);
+            spatial_volume = 1.0f / (1.0f + (distance / kDefaultFalloffDistance) * (distance / kDefaultFalloffDistance));
+        }
+
+        voice.volume = voice.volume * voice.fade_volume * spatial_volume * m_master_volume;
+    }
+}
+
+Voice* AudioManager::find_free_voice() {
+    for (auto& voice : m_voices) {
+        if (!voice.active) return &voice;
+    }
+    return nullptr;
+}
+
+Voice* AudioManager::find_voice_by_id(uint32_t id) {
+    for (auto& voice : m_voices) {
+        if (voice.id == id && voice.active) return &voice;
+    }
+    return nullptr;
+}
+
+Voice* AudioManager::steal_lowest_priority_voice() {
+    Voice* quietest = nullptr;
+    float min_volume = std::numeric_limits<float>::max();
+
+    for (auto& voice : m_voices) {
+        if (voice.active && !voice.looping && voice.volume < min_volume) {
+            min_volume = voice.volume;
+            quietest = &voice;
+        }
+    }
+    return quietest;
+}
+
+} // namespace audio


