+void Renderer::enable_debug_overlay(bool enabled) {
+    m_debug_overlay_enabled = enabled;
+    if (enabled) {
+        m_debug_line_buffer.reserve(1024);
+    }
+}
+
+void Renderer::draw_debug_line(const glm::vec3& from, const glm::vec3& to, const glm::vec4& color) {
+    if (!m_debug_overlay_enabled) return;
+    m_debug_line_buffer.push_back({from, to, color});
+}
+
+void Renderer::flush_debug_overlay() {
+    if (!m_debug_overlay_enabled || m_debug_line_buffer.empty()) return;
+
+    auto* debug_shader = m_shader_pipeline.count("debug")
+        ? m_shader_pipeline["debug"].get()
+        : get_active_shader();
+    debug_shader->set_uniform("u_view_projection", m_view * m_projection);
+    // ... batch upload and draw call
+    m_debug_line_buffer.clear();
+}
