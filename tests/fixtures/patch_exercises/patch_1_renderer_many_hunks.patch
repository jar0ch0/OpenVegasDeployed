+        "geometry", "lighting", "post_process", "ui_overlay"
+    };
+
+    for (const auto& stage : stages) {
+        auto shader = std::make_unique<Shader>();
+        std::string vert = shader_path + "/" + stage + ".vert";
+        std::string frag = shader_path + "/" + stage + ".frag";
+        if (!shader->compile(vert, frag)) return false;
+        m_shader_pipeline[stage] = std::move(shader);
     }
-    m_default_shader->bind();
-    return true;
+    return !m_shader_pipeline.empty();
